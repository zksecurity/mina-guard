{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "prisma migrate deploy",
    "dev": "bun run db:migrate && bun --env-file=.env --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun run db:migrate && bun dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:fixtures": "bun run scripts/seed-fixtures.ts"
  },
  "dependencies": {
    "@prisma/client": "6.12.0",
    "contracts": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "prisma": "6.12.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}