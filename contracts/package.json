{
  "name": "contracts",
  "version": "0.1.0",
  "description": "Multisig on Mina, with o1js",
  "author": "",
  "license": "Apache-2.0",
  "keywords": [
    "mina-zkapp",
    "mina-zk-app",
    "mina-dapp",
    "zkapp"
  ],
  "type": "module",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "buildw": "tsc --watch",
    "coverage": "bun test --timeout 20000 --coverage",
    "format": "prettier --write --ignore-unknown **/*",
    "test": "bun test --timeout 20000",
    "test:proofs": "bun test --timeout 1000000 src/tests/batch-verify.test.ts",
    "testw": "bun test --timeout 20000 --watch",
    "testjs": "bun run build && find build/src -name '*.test.js' -exec node --test {} \\;",
    "lint": "eslint src/* --fix",
    "typecheck": "bun run tsc --noEmit"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-typescript": "^7.16.0",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^5.5.0",
    "@typescript-eslint/parser": "^5.5.0",
    "eslint": "^8.7.0",
    "eslint-plugin-o1js": "^0.4.0",
    "prettier": "^2.3.2",
    "ts-jest": "^29.2.4",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "o1js": "2.13.0"
  },
  "engines": {
    "node": ">=18.14.0"
  }
}